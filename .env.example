# ============================================================
#  CONECTE TELECOM — Landing Page
#  Variáveis de Ambiente
#
#  1. Copie este arquivo: cp .env.example .env
#  2. Preencha os valores reais
#  3. NUNCA faça commit do arquivo .env
# ============================================================

# ── Asaas (Sistema de Cobranças) ─────────────────────────────
# Obtenha em: asaas.com → Configurações → Integrações → API Key
# Produção:  começa com $aact_...
# Sandbox:   começa com $aact_... (ambiente de testes)
ASAAS_API_KEY=sua_chave_aqui

# ── Resend (Envio de E-mails) ─────────────────────────────────
# Obtenha em: resend.com → API Keys → Create API Key
# Plano gratuito: 3.000 e-mails/mês
RESEND_API_KEY=re_sua_chave_aqui

# ── E-mail Remetente ──────────────────────────────────────────
# Deve ser um domínio verificado no Resend
# Ex: noreply@seconecte.net
OTP_FROM_EMAIL=noreply@seudominio.com